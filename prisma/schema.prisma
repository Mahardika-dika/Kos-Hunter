// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
  compilerBuild = "fast"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     Role

  kos     Kos[]
  reviews Reviews[]
  books   Books[]
}

model Kos {
  id              Int    @id @default(autoincrement())
  user_id         Int
  name            String
  address         String
  price_per_month Int
  gender          Gender
  description     String

  user Users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  kosImages     KosImage[]
  kosFasilities KosFasilities?
  reviews       Reviews[]
  books         Books[]

  @@index([user_id])
  @@index([gender, price_per_month])
}

model KosImage {
  id     Int  @id @default(autoincrement())
  kos_id Int  @unique
  file   Json

  kos Kos @relation(fields: [kos_id], references: [id], onDelete: Cascade)

  @@index([kos_id])
}

model KosFasilities {
  id       Int  @id @default(autoincrement())
  kos_id   Int  @unique
  fasility Json

  kos Kos @relation(fields: [kos_id], references: [id], onDelete: Cascade)
}

model Reviews {
  id      Int    @id @default(autoincrement())
  kos_id  Int
  comment String
  user_id Int?

  kos  Kos    @relation(fields: [kos_id], references: [id], onDelete: Cascade)
  user Users? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@unique([user_id, kos_id])
  @@index([kos_id])
}

model Books {
  id         Int       @id @default(autoincrement())
  kos_id     Int
  user_id    Int
  status     Status    @default(PENDING)
  start_date DateTime
  end_date   DateTime?

  kos  Kos   @relation(fields: [kos_id], references: [id])
  user Users @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([kos_id])
}

enum Role {
  OWNER
  SOCIETY
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  ALL
}

enum Status {
  ACCEPTED
  PENDING
  REJECT
}
