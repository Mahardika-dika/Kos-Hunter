// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Users {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     Role?

  // Table Relation
  kos     Kos[]
  reviews Reviews[]
  books   Books[]
}

model Kos {
  id              Int     @id @default(autoincrement())
  user_id         Int
  name            String
  address         String
  price_per_month Int
  gender          Gender?

  // Table Relation
  user Users @relation(fields: [user_id], references: [id])

  kosImages     KosImage[]
  kosFasilities KosFasilities[]
  reviews       Reviews[]
  books         Books[]
}

model KosImage {
  id     Int    @id @default(autoincrement())
  kos_id Int
  file   String

  // Table Relation
  kos Kos @relation(fields: [kos_id], references: [id])
}

model KosFasilities {
  id       Int  @id @default(autoincrement())
  kos_id   Int
  fasility Json

  // Table Relation
  kos Kos @relation(fields: [kos_id], references: [id])
}

model Reviews {
  id      Int    @id @default(autoincrement())
  kos_id  Int
  comment String
  user_id Int

  // Table Relation
  kos  Kos   @relation(fields: [kos_id], references: [id])
  user Users @relation(fields: [user_id], references: [id])
}

model Books {
  id         Int       @id @default(autoincrement())
  kos_id     Int
  user_id    Int
  start_date DateTime
  end_date   DateTime?

  // Table Relation
  kos  Kos   @relation(fields: [kos_id], references: [id])
  user Users @relation(fields: [user_id], references: [id])
}

enum Role {
  OWNER
  SOCIETY
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum Status {
  ACCEPTED
  PENDING
  REJECT
}
